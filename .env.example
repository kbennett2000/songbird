# songbird configuration — copy to .env and edit. (.env is gitignored.)

# Port songbird's single process listens on.
PORT=8077

# Where songbird keeps its OWN SQLite DB (annotations/tags/users land here in later
# slices). No Bible text ever lives here — that comes from Concord over HTTP.
DATA_DIR=./data

# Concord is a HARD runtime HTTP dependency. Point this at a reachable Concord instance.
# It may be the same host or any other machine on the LAN, on any port — songbird makes no
# co-location assumption; it calls whatever URL it is given.
#
#   Local dev (uvicorn on the host, Concord on the host):  http://localhost:8000
#   songbird in Docker, Concord on the host:               http://host.docker.internal:8000
#   Concord on another LAN machine:                         http://192.168.1.62:8000
#
# If Concord is unreachable, songbird errors — there is no offline fallback.
CONCORD_BASE_URL=http://localhost:8000

# Session cookie `Secure` flag. Leave false for the default LAN-HTTP deploy; set to 1/true the
# moment songbird is fronted with TLS, so the session cookie is only sent over HTTPS.
# See docs/SECURITY.md for the full exposing-beyond-LAN checklist.
COOKIE_SECURE=false
