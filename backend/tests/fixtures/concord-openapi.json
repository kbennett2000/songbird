{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Liveness payload with real loaded-translation, verse, and cross-ref counts.",
        "properties": {
          "book_count": {
            "default": 0,
            "title": "Book Count",
            "type": "integer"
          },
          "cross_ref_count": {
            "default": 0,
            "title": "Cross Ref Count",
            "type": "integer"
          },
          "place_count": {
            "default": 0,
            "title": "Place Count",
            "type": "integer"
          },
          "semantic": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SemanticHealth"
              },
              {
                "type": "null"
              }
            ]
          },
          "status": {
            "const": "ok",
            "default": "ok",
            "title": "Status",
            "type": "string"
          },
          "translation_count": {
            "default": 0,
            "title": "Translation Count",
            "type": "integer"
          },
          "verse_count": {
            "default": 0,
            "title": "Verse Count",
            "type": "integer"
          }
        },
        "title": "HealthResponse",
        "type": "object"
      },
      "SemanticHealth": {
        "description": "Semantic-search readiness: the embedded translation, vector count, model, and dim.",
        "properties": {
          "dim": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dim"
          },
          "embedding_count": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Embedding Count"
          },
          "enabled": {
            "title": "Enabled",
            "type": "boolean"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model"
          },
          "translation": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Translation"
          }
        },
        "required": [
          "enabled"
        ],
        "title": "SemanticHealth",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
